  {
    "name": "createUser",
    "method": "POST",
    "path": "/api/users",
    "summary": "创建用户",
    "description": "创建新用户（管理员权限）",
    "auth_required": true,
    "tags": [
      "用户管理"
    ],
    "request_body": {
      "content_type": "application/json",
      "schema": {
        "type": "object",
        "required": [
          "username",
          "password",
          "role"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "nickname": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "user",
              "guest"
            ]
          }
        }
      },
      "example": {
        "username": "testuser",
        "password": "123456",
        "role": "user"
      },
      "required_fields": [
        "username",
        "password",
        "role"
      ]
    },
    "response_schemas": {
      "201": {
        "schema": {},
        "example": {
          "code": 0,
          "data": {
            "id": 3,
            "username": "testuser"
          }
        }
      }
    },
    "examples": {
      "request_example": {
        "username": "testuser",
        "password": "123456",
        "role": "user"
      },
      "response_example": {
        "code": 0,
        "data": {
          "id": 3,
          "username": "testuser"
        }
      }
    }
  },
