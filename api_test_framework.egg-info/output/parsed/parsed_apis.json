[
  {
    "name": "login",
    "method": "POST",
    "path": "/api/auth/login",
    "summary": "用户登录",
    "description": "通过用户名和密码登录，返回 JWT Token",
    "auth_required": false,
    "tags": [
      "认证"
    ],
    "request_body": {
      "content_type": "application/json",
      "schema": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "example": "admin"
          },
          "password": {
            "type": "string",
            "description": "密码",
            "example": "admin123"
          }
        }
      },
      "example": {
        "username": "admin",
        "password": "admin123"
      },
      "required_fields": [
        "username",
        "password"
      ]
    },
    "response_schemas": {
      "200": {
        "schema": {
          "type": "object"
        },
        "example": {
          "code": 0,
          "message": "success",
          "data": {
            "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
            "user": {
              "id": 1,
              "username": "admin",
              "nickname": "管理员"
            }
          }
        }
      }
    },
    "examples": {
      "request_example": {
        "username": "admin",
        "password": "admin123"
      },
      "response_example": {
        "code": 0,
        "message": "success",
        "data": {
          "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
          "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
          "user": {
            "id": 1,
            "username": "admin",
            "nickname": "管理员"
          }
        }
      }
    }
  },
  {
    "name": "register",
    "method": "POST",
    "path": "/api/auth/register",
    "summary": "用户注册",
    "description": "注册新用户",
    "auth_required": false,
    "tags": [
      "认证"
    ],
    "request_body": {
      "content_type": "application/json",
      "schema": {
        "type": "object",
        "required": [
          "username",
          "password",
          "email"
        ],
        "properties": {
          "username": {
            "type": "string",
            "minLength": 3,
            "maxLength": 20,
            "description": "用户名"
          },
          "password": {
            "type": "string",
            "minLength": 6,
            "maxLength": 32,
            "description": "密码"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "邮箱"
          },
          "nickname": {
            "type": "string",
            "description": "昵称"
          }
        }
      },
      "example": {
        "username": "newuser",
        "password": "123456",
        "email": "new@example.com"
      },
      "required_fields": [
        "username",
        "password",
        "email"
      ]
    },
    "response_schemas": {
      "201": {
        "schema": {},
        "example": {
          "code": 0,
          "message": "注册成功",
          "data": {
            "id": 2,
            "username": "newuser"
          }
        }
      }
    },
    "examples": {
      "request_example": {
        "username": "newuser",
        "password": "123456",
        "email": "new@example.com"
      },
      "response_example": {
        "code": 0,
        "message": "注册成功",
        "data": {
          "id": 2,
          "username": "newuser"
        }
      }
    }
  },
